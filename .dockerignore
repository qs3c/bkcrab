# VCS and local assistant/runtime state
.git/
.claude/
.agents/
.kilo/
.worktrees/
workspace/

# Repository metadata/docs not used by the image build
.github/
docs/
deploy/
.goreleaser.yaml
Makefile
install.sh
extract_comments.py

# Build outputs and dependency caches
bin/
dist/
tmp/
internal/setup/web/
node_modules/
**/node_modules/
web/.next/
web/out/
vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.prof

# Local previews and debug artifacts
previews/
debug/
__debug_bin*
all_comments.txt
DESIGN.md
bkcrab-patched
.air.toml

# Editor and OS files
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment, credentials, and local config
.env
.env.*
*.pem
*.key
config.json
bkcrab.json
openclaw.json
env.toml
go.work
go.work.sum

# Keep the runtime entrypoint script needed by Dockerfile while excluding
# other development scripts from the image build context.
scripts/*
!scripts/docker-entrypoint.sh

# Keep only the Go migration tool from tools/
tools/*
!tools/migrate-storage/
!tools/migrate-storage/**

# Archives
*.tar.gz
*.zip
