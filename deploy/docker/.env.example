MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password
MINIO_ROOT_USER=bkcrab
MINIO_ROOT_PASSWORD=replace-with-a-long-random-password
MINIO_BUCKET=bkcrab
MINIO_PREFIX=
BKCRAB_PORT=18953
BKCRAB_SANDBOX_IMAGE=thinkany/bkcrab-sandbox:latest
MINIO_API_PORT=19000
MINIO_CONSOLE_PORT=19001
TZ=Asia/Shanghai

# Optional RAG overlay (docker-compose.rag.yml).
# The endpoint is an OpenAI-compatible base URL; BkCrab appends /embeddings.
RAG_EMBEDDING_ENDPOINT=https://example.com/v1
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_MODEL=text-embedding-model
RAG_EMBEDDING_DIMS=1024

# Optional llama.cpp/Jina-compatible reranker. When using
# docker-compose.models.yml, use http://qwen3-reranker:8080/v1.
RAG_RERANKER_ENABLED=false
RAG_RERANKER_ENDPOINT=http://qwen3-reranker:8080/v1
RAG_RERANKER_API_KEY=
RAG_RERANKER_MODEL=qwen3-reranker
RAG_RERANKER_TIMEOUT_MS=5000
RAG_RERANKER_CANDIDATE_TOP_K=20
RAG_RERANKER_MIN_SCORE=0.5

# Sandboxed document parser sidecar. Keep the image pinned to an immutable
# release tag (or digest) in production; never use latest/dev.
RAG_PARSER_IMAGE=bkcrab/rag-parser:0.1.0
RAG_PARSER_SERVICE_VERSION=0.1.0
RAG_PARSER_CPUS=1.0
RAG_PARSER_MEMORY_LIMIT=1g
RAG_PARSER_TMPFS_SIZE_BYTES=536870912

# Parser and main-service limits. The parser receives these same canonical
# values and derives maxInputBytes and timeout seconds at startup. There are no
# independently configurable byte/second aliases to drift.
RAG_MAX_FILE_MB=50
RAG_MAX_PAGES_PER_DOCUMENT=300
RAG_MAX_ASSETS_PER_DOCUMENT=500
RAG_MAX_ASSET_BYTES=20971520
RAG_MAX_EXTRACTED_BYTES=209715200
RAG_MAX_IMAGE_PIXELS=40000000
RAG_PDF_RENDER_DPI=180
RAG_PARSE_TIMEOUT_MS=600000

# Advanced parsing, Office parsing and text enrichment are independent release
# gates and remain off by default. Enable only after the documented rollout
# checks have passed.
RAG_ADVANCED_ENABLED=false
RAG_OFFICE_ENABLED=false
RAG_ENRICHMENT_ENABLED=false

# Ingestion-only DocumentAI endpoint. The key is injected into bkcrab only and
# is never exposed to rag-parser. HTTPS is the safe default; private/HTTP
# endpoints require the explicit policy switch and an exact host allow-list.
RAG_DOCUMENT_AI_API_TYPE=openai-compatible
RAG_DOCUMENT_AI_ENDPOINT=
RAG_DOCUMENT_AI_API_KEY=
RAG_DOCUMENT_AI_VISION_MODEL=
RAG_DOCUMENT_AI_TEXT_MODEL=
# Use json_object for providers such as Xiaomi MiMo that guarantee JSON mode
# but do not enforce OpenAI's json_schema response format.
RAG_DOCUMENT_AI_RESPONSE_FORMAT=json_schema
RAG_DOCUMENT_AI_VISION_PROMPT_VERSION=vision-v3
RAG_DOCUMENT_AI_ALLOWED_ENDPOINT_HOSTS=
RAG_DOCUMENT_AI_ALLOW_PRIVATE_ENDPOINT=false

# Leave both empty unless Milvus authorization is enabled.
MILVUS_USERNAME=
MILVUS_PASSWORD=

# The optional overlay binds these ports to this host address. Keep 127.0.0.1
# unless a trusted LAN client (such as Attu) needs access. For this server, use
# 192.168.1.72 rather than 0.0.0.0 to avoid exposing Milvus on every interface.
MILVUS_BIND_ADDRESS=127.0.0.1
MILVUS_PORT=19530
MILVUS_WEB_PORT=19091
